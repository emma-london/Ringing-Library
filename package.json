{
  "name": "ringing-lib-ts",
  "version": "1.3.0",
  "description": "A TypeScript library for change ringing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./data/standard-set": {
      "types": "./dist/data/standard-set.d.ts",
      "import": "./dist/data/standard-set.js"
    },
    "./cccbr-methods": {
      "types": "./dist/cccbr/index.d.ts",
      "import": "./dist/cccbr/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "//private": "Set to false (and pick the package name + license below) when actually ready to publish — ADR-0016. Prevents an accidental `npm publish` in the meantime.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emma-london/Ringing-Library.git"
  },
  "homepage": "https://github.com/emma-london/Ringing-Library#readme",
  "bugs": {
    "url": "https://github.com/emma-london/Ringing-Library/issues"
  },
  "keywords": [
    "change-ringing",
    "bell-ringing",
    "campanology",
    "method-ringing",
    "typescript"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:example-touches": "node scripts/generate-example-touches.mjs",
    "data:refresh": "npm run build && node scripts/refresh-method-library.mjs",
    "engine:live-diff": "npm run build && node scripts/engine-live-diff.mjs",
    "app:dev": "vite app",
    "app:build": "vite build app",
    "app:preview": "vite preview app"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
