# Dependencies
node_modules/

# TypeScript build output (tsconfig outDir)
dist/
*.tsbuildinfo

# Vite app build output (app/) and cache (ADR-0010)
app/dist/
.vite/

# Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# C++ prototype build artifacts (prototypes/)
prototypes/gsearch
prototypes/solver
prototypes/solver_mt
prototypes/grandsire
prototypes/touches
*.out
*.o
*.obj
*.exe
*.dSYM/

# Generated CCCBR method-library snapshot (ADR-0015) — a build artifact,
# regenerated via `npm run data:refresh` (or in CI), not vendored into git.
# The hand-maintained standard-set SEED lives in src/data/ and IS tracked.
data/method-library/

# Rust / WASM engine build output (ADR-0001)
target/
pkg/
*.wasm
wasm-pack.log

# Environment / secrets
.env
.env.*
!.env.example

# Local scratch / experiment files — underscore-prefixed is the project
# convention for throwaway scripts (e.g. src/_oracle.ts, src/_trace.ts).
# Also excluded from the tsc build in tsconfig.json, so they can never break it.
_*.ts
scratch/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS cruft
.DS_Store
Thumbs.db
